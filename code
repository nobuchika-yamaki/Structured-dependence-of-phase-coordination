    plt.tight_layout()
    plt.savefig(os.path.join(OUTDIR, "Fig5_factor_effects_phase_lag.png"), dpi=300)
    plt.close()

    # Fig 6: parameter robustness
    fig, axes = plt.subplots(2, 2, figsize=(10, 7), constrained_layout=True)
    for ax, sweep_name in zip(axes.ravel(), ["alpha", "g", "tau_a", "c"]):
        sub = robust_summary[(robust_summary["sweep_parameter"] == sweep_name) & (robust_summary["condition"].isin(["Full", "NoAsym", "NoAdapt", "NoTSsep"]))]
