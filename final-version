# Non-monotonic checks
# ============================================================
def run_transition_checks(trial_df, local_df, regime_df):
    rows = []

    for human_name, cond_name in MAIN_FOUR.items():
        full_trial_sub = trial_df[trial_df["condition"] == cond_name].copy()

        for primary_metric, trial_col in [("lag_mean", "mean_phase_lag"), ("plv_mean", "plv")]:
            loc = local_df[(local_df["condition"] == cond_name) & (local_df["metric"] == primary_metric)].copy()
            reg = regime_df[(regime_df["condition"] == cond_name) & (regime_df["metric"] == primary_metric)].copy()

            loc = loc.sort_values("mid_log10_delta_f")
            slopes = loc["local_slope"].values
            mids = loc["mid_log10_delta_f"].values

            sign_changes = 0
            for i in range(1, len(slopes)):
                s1 = np.sign(slopes[i - 1])
                s2 = np.sign(slopes[i])
                if s1 != 0 and s2 != 0 and s1 != s2:
                    sign_changes += 1

            high_mask = mids > 0.0
            pos_high = slopes[high_mask] > 0 if np.any(high_mask) else np.array([], dtype=bool)
            contiguous_positive_high_len = longest_contiguous_true(pos_high)
            criterion_1 = contiguous_positive_high_len >= 1

            reg_map = {r["regime"]: r["slope"] for _, r in reg.iterrows()}
            criterion_2 = False
            if "low" in reg_map and "mid" in reg_map:
                if np.sign(reg_map["low"]) != np.sign(reg_map["mid"]) or abs(reg_map["low"] - reg_map["mid"]) > 1e-10:
                    criterion_2 = True
            if "mid" in reg_map and "high" in reg_map:
                if np.sign(reg_map["mid"]) != np.sign(reg_map["high"]) or abs(reg_map["mid"] - reg_map["high"]) > 1e-10:
                    criterion_2 = True

            trial_repro_flags = []
            for trial, sub in full_trial_sub.groupby("trial"):
                sub = sub.sort_values("delta_f")
                x = np.log10(sub["delta_f"].values)
                y = sub[trial_col].values
                _, slopes_t = local_slopes(x, y)
                sc = 0
                for i in range(1, len(slopes_t)):
                    s1 = np.sign(slopes_t[i - 1])
                    s2 = np.sign(slopes_t[i])
                    if s1 != 0 and s2 != 0 and s1 != s2:
                        sc += 1
                trial_repro_flags.append(sc >= 1)

            reproducibility_rate = float(np.mean(trial_repro_flags)) if len(trial_repro_flags) > 0 else np.nan
            criterion_3 = reproducibility_rate >= 0.5

            secondary_support = []
            for sec_metric in ["mean_domega_eff_mean", "D_phi_mean", "r_slip_mean"]:
                sec_loc = local_df[(local_df["condition"] == cond_name) & (local_df["metric"] == sec_metric)].copy()
                sec_reg = regime_df[(regime_df["condition"] == cond_name) & (regime_df["metric"] == sec_metric)].copy()

                sec_loc = sec_loc.sort_values("mid_log10_delta_f")
                sec_slopes = sec_loc["local_slope"].values
                sec_mids = sec_loc["mid_log10_delta_f"].values
                sec_high_mask = sec_mids > 0.0
                sec_pos_high = sec_slopes[sec_high_mask] > 0 if np.any(sec_high_mask) else np.array([], dtype=bool)

                sec_reg_map = {r["regime"]: r["slope"] for _, r in sec_reg.iterrows()}
                sec_change = False
                if "mid" in sec_reg_map and "high" in sec_reg_map:
                    if np.sign(sec_reg_map["mid"]) != np.sign(sec_reg_map["high"]) or abs(sec_reg_map["mid"] - sec_reg_map["high"]) > 1e-10:
                        sec_change = True

                sec_support = (longest_contiguous_true(sec_pos_high) >= 1) or sec_change
                secondary_support.append((sec_metric, sec_support))

            criterion_4 = any(flag for _, flag in secondary_support)

            rows.append(
                {
                    "condition": cond_name,
                    "condition_group": human_name,
                    "primary_metric": primary_metric,
                    "n_sign_changes": int(sign_changes),
                    "contiguous_positive_high_len": int(contiguous_positive_high_len),
                    "criterion_1_positive_interval_high": bool(criterion_1),
                    "criterion_2_regime_change": bool(criterion_2),
                    "reproducibility_rate": reproducibility_rate,
                    "criterion_3_reproducible": bool(criterion_3),
                    "secondary_support_details": "; ".join([f"{m}:{int(v)}" for m, v in secondary_support]),
                    "criterion_4_secondary_change": bool(criterion_4),
                    "all_criteria_satisfied": bool(criterion_1 and criterion_2 and criterion_3 and criterion_4),
                }
            )

    checks_df = pd.DataFrame(rows)
    checks_df.to_csv(os.path.join(OUTDIR, "nonmonotonic_transition_checks.csv"), index=False)
    return checks_df


# ============================================================
# Factorial analysis
# ============================================================
def ols_with_inference(df: pd.DataFrame, ycol: str):
    X = pd.DataFrame({
        "Intercept": np.ones(len(df), dtype=float),
        "A": df["asymmetry"].astype(float).values,
        "G": df["adaptation"].astype(float).values,
        "T": df["timescale_separation"].astype(float).values,
    })
    X["AG"] = X["A"] * X["G"]
    X["AT"] = X["A"] * X["T"]
    X["GT"] = X["G"] * X["T"]
    X["AGT"] = X["A"] * X["G"] * X["T"]

    y = df[ycol].astype(float).values
    Xmat = X.values

    beta, _, _, _ = np.linalg.lstsq(Xmat, y, rcond=None)
    yhat = Xmat @ beta
    resid = y - yhat

    n = len(y)
    p = Xmat.shape[1]
    df_resid = n - p
    ss_res = np.sum(resid ** 2)
    ss_tot = np.sum((y - np.mean(y)) ** 2)
    r2 = 1.0 - ss_res / ss_tot if ss_tot > 0 else np.nan

    xtx_inv = np.linalg.inv(Xmat.T @ Xmat)
    sigma2 = ss_res / df_resid if df_resid > 0 else np.nan
    se = np.sqrt(np.diag(xtx_inv) * sigma2) if df_resid > 0 else np.full(p, np.nan)

    if df_resid > 0:
        tvals = beta / se
        pvals = 2.0 * (1.0 - student_t.cdf(np.abs(tvals), df=df_resid))
        tcrit = student_t.ppf(0.975, df=df_resid)
        ci_low = beta - tcrit * se
        ci_high = beta + tcrit * se
    else:
        tvals = np.full(p, np.nan)
        pvals = np.full(p, np.nan)
        ci_low = np.full(p, np.nan)
        ci_high = np.full(p, np.nan)

    out = pd.DataFrame({
        "term": X.columns,
        "beta": beta,
        "se": se,
        "t": tvals,
        "p": pvals,
        "ci_low": ci_low,
        "ci_high": ci_high,
        "r2_model": r2,
        "n": n,
        "df_resid": df_resid,
        "response": ycol,
    })
    return out


def run_factorial_analyses(sens_df, structure_df):
    sens_out = []
    for ycol in ["S_LAG", "S_PLV", "S_DOMEGA", "S_DPHI", "S_RSLIP"]:
