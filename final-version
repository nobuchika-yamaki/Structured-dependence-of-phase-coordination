def run_parameter_robustness():
    rows = []
    full = Condition(1, 1, 1)
    reduced_variants = {
        "Full": full,
        "NoAsym": Condition(0, 1, 1),
        "NoAdapt": Condition(1, 0, 1),
        "NoTSsep": Condition(1, 1, 0),
    }

    sweep_specs = {
        "alpha": ALPHA_SWEEP,
        "g": G_SWEEP,
        "tau_a": TAU_A_SWEEP,
        "c": C_SWEEP,
    }

    for sweep_name, sweep_values in sweep_specs.items():
        print(f"Robustness sweep: {sweep_name}")
        for sweep_value in sweep_values:
            for label, cond in reduced_variants.items():
                for trial in range(20):
                    lag_values = []
                    plv_values = []
                    domega_values = []
                    dphi_values = []
                    rslip_values = []

                    for delta_f in DELTA_F_VALUES:
                        kwargs = {}
                        if sweep_name == "alpha":
                            kwargs["alpha_on"] = sweep_value
                        elif sweep_name == "g":
                            kwargs["g_on"] = sweep_value
                        elif sweep_name == "tau_a":
                            kwargs["tau_a_on"] = sweep_value
                        elif sweep_name == "c":
                            kwargs["c_on"] = sweep_value

                        seed = trial_seed("robust", sweep_name, sweep_value, label, delta_f, trial)
                        res = simulate_condition(cond, float(delta_f), seed, **kwargs)

                        lag_values.append(res["mean_phase_lag"])
                        plv_values.append(res["plv"])
                        domega_values.append(res["mean_domega_eff"])
                        dphi_values.append(res["D_phi"])
                        rslip_values.append(res["r_slip"])

                    x = np.log10(DELTA_F_VALUES)
                    coef_lag = np.polyfit(x, np.asarray(lag_values), 1)
                    coef_plv = np.polyfit(x, np.asarray(plv_values), 1)
                    coef_domega = np.polyfit(x, np.asarray(domega_values), 1)
                    coef_dphi = np.polyfit(x, np.asarray(dphi_values), 1)
                    coef_rslip = np.polyfit(x, np.asarray(rslip_values), 1)

                    rows.append(
                        {
                            "sweep_parameter": sweep_name,
                            "sweep_value": float(sweep_value),
                            "condition": label,
                            "S_LAG": float(coef_lag[0]),
                            "S_PLV": float(coef_plv[0]),
                            "S_DOMEGA": float(coef_domega[0]),
                            "S_DPHI": float(coef_dphi[0]),
                            "S_RSLIP": float(coef_rslip[0]),
                        }
                    )

    robust_df = pd.DataFrame(rows)
    robust_df.to_csv(os.path.join(OUTDIR, "parameter_robustness_trialwise.csv"), index=False)

    robust_summary = (
        robust_df.groupby(["sweep_parameter", "sweep_value", "condition"], as_index=False)
        .agg(
            S_LAG_mean=("S_LAG", "mean"),
            S_PLV_mean=("S_PLV", "mean"),
            S_DOMEGA_mean=("S_DOMEGA", "mean"),
            S_DPHI_mean=("S_DPHI", "mean"),
            S_RSLIP_mean=("S_RSLIP", "mean"),
        )
    )
    robust_summary.to_csv(os.path.join(OUTDIR, "parameter_robustness_summary.csv"), index=False)
    return robust_df, robust_summary


