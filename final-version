# ============================================================
# Utilities
# ============================================================
@dataclass(frozen=True)
class Condition:
    asymmetry: int
    adaptation: int
    timescale_separation: int

    def name(self) -> str:
        return f"A{self.asymmetry}_G{self.adaptation}_T{self.timescale_separation}"

    def label(self) -> str:
        parts = [
            "Asym" if self.asymmetry else "Sym",
            "Adapt" if self.adaptation else "NoAdapt",
            "TSsep" if self.timescale_separation else "NoTSsep",
        ]
        return ", ".join(parts)


def sigmoid(u):
    return 1.0 / (1.0 + np.exp(-GAMMA * (u - THETA)))


def analytic_signal(x: np.ndarray) -> np.ndarray:
    n = len(x)
    Xf = np.fft.fft(x)
    h = np.zeros(n)
    if n % 2 == 0:
        h[0] = 1
        h[n // 2] = 1
        h[1:n // 2] = 2
    else:
        h[0] = 1
        h[1:(n + 1) // 2] = 2
    return np.fft.ifft(Xf * h)


def bootstrap_ci(values: np.ndarray, n_boot: int = 500, ci: float = 95.0, seed: int = 1234):
    rng = np.random.default_rng(seed)
    values = np.asarray(values, dtype=float)
    n = len(values)
    boots = np.empty(n_boot)
    for i in range(n_boot):
        sample = rng.choice(values, size=n, replace=True)
        boots[i] = sample.mean()
    low = np.percentile(boots, (100 - ci) / 2)
    high = np.percentile(boots, 100 - (100 - ci) / 2)
    return float(low), float(high)


def r2_score(y, yhat):
    y = np.asarray(y, dtype=float)
    yhat = np.asarray(yhat, dtype=float)
    ss_res = np.sum((y - yhat) ** 2)
    ss_tot = np.sum((y - np.mean(y)) ** 2)
    return float(1.0 - ss_res / ss_tot) if ss_tot > 0 else np.nan


def trial_seed(*parts) -> int:
    return BASE_SEED + (hash(parts) % 10_000_000)


def local_slopes(x: np.ndarray, y: np.ndarray):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)
    mids = 0.5 * (x[:-1] + x[1:])
    slopes = np.diff(y) / np.diff(x)
    return mids, slopes


def turning_points(x: np.ndarray, y: np.ndarray):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)
    dy = np.diff(y)
    signs = np.sign(dy)
    out = []
    for i in range(1, len(signs)):
        if signs[i - 1] > 0 and signs[i] < 0:
            out.append({"type": "local_max", "x": float(x[i]), "y": float(y[i]), "index": int(i)})
        elif signs[i - 1] < 0 and signs[i] > 0:
            out.append({"type": "local_min", "x": float(x[i]), "y": float(y[i]), "index": int(i)})
    return out


def piecewise_linear_two_segment(x: np.ndarray, y: np.ndarray):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)
    best = None
    for split in range(2, len(x) - 2):
        x1, y1 = x[:split + 1], y[:split + 1]
        x2, y2 = x[split:], y[split:]
        c1 = np.polyfit(x1, y1, 1)
        c2 = np.polyfit(x2, y2, 1)
        yhat1 = np.polyval(c1, x1)
        yhat2 = np.polyval(c2, x2)
        sse = np.sum((y1 - yhat1) ** 2) + np.sum((y2 - yhat2) ** 2)
        if best is None or sse < best["sse"]:
            yhat = np.concatenate([yhat1[:-1], yhat2])
            best = {
                "split_index": split,
                "split_x": float(x[split]),
                "coef1": c1,
                "coef2": c2,
                "sse": float(sse),
                "r2": r2_score(y, yhat),
                "yhat": yhat,
            }
    return best


def longest_contiguous_true(mask: np.ndarray) -> int:
    max_len = 0
    cur = 0
    for v in mask:
        if v:
            cur += 1
            max_len = max(max_len, cur)
        else:
            cur = 0
    return max_len


def mean_sem(x):
    x = np.asarray(x, dtype=float)
    return float(np.mean(x)), float(np.std(x, ddof=1) / np.sqrt(len(x)))


# ============================================================
# Phase metrics
# ============================================================
def phase_metrics_from_signals(x_l: np.ndarray, x_r: np.ndarray, dt: float):
    z_l = analytic_signal(x_l)
    z_r = analytic_signal(x_r)

    phi_l_wrapped = np.angle(z_l)
    phi_r_wrapped = np.angle(z_r)

    phi_l = np.unwrap(phi_l_wrapped)
    phi_r = np.unwrap(phi_r_wrapped)

    delta_phi = np.angle(np.exp(1j * (phi_l - phi_r)))
    delta_phi_u = np.unwrap(phi_l - phi_r)

    z = np.exp(1j * delta_phi).mean()
    plv = float(np.abs(z))
    mean_phase_lag = float(np.abs(np.angle(z)))
    signed_mean_phase_lag = float(np.angle(z))

    r = max(min(plv, 1.0), 1e-12)
    circ_sd = float(np.sqrt(-2.0 * np.log(r)))

    if len(delta_phi_u) >= 2:
        domega_eff_ts = np.diff(delta_phi_u) / dt
        mean_domega_eff = float(np.mean(domega_eff_ts))
    else:
        domega_eff_ts = np.array([], dtype=float)
        mean_domega_eff = np.nan

    t_vec = np.arange(len(delta_phi_u), dtype=float) * dt
    if len(delta_phi_u) > 0:
        psi = delta_phi_u - mean_domega_eff * t_vec
        T_an = len(delta_phi_u) * dt
        D_phi = float(np.var(psi, ddof=1) / (2.0 * T_an)) if len(psi) >= 2 else np.nan
    else:
        psi = np.array([], dtype=float)
        T_an = 0.0
        D_phi = np.nan

    cycle_index = np.floor(delta_phi_u / (2.0 * np.pi))
    if len(cycle_index) >= 2:
        slip_jumps = np.diff(cycle_index)
        N_slip = int(np.sum(np.abs(slip_jumps) > 0))
    else:
        N_slip = 0

    r_slip = float(N_slip / T_an) if T_an > 0 else np.nan

    return {
        "plv": plv,
        "mean_phase_lag": mean_phase_lag,
        "signed_mean_phase_lag": signed_mean_phase_lag,
        "circ_sd": circ_sd,
        "mean_domega_eff": mean_domega_eff,
        "D_phi": D_phi,
        "N_slip": N_slip,
        "r_slip": r_slip,
        "delta_phi": delta_phi,
        "delta_phi_u": delta_phi_u,
        "phi_l": phi_l,
        "phi_r": phi_r,
        "domega_eff_ts": domega_eff_ts,
    }


# ============================================================
# Simulation
# ============================================================
def simulate_condition(
    cond: Condition,
    delta_f: float,
    seed: int,
    tau_x: float = TAU_X,
    tau_a_on: float = TAU_A_ON,
    w0: float = W0,
    c_on: float = C_ON,
    alpha_on: float = ALPHA_ON,
    g_on: float = G_ON,
    tau_delay: float = TAU_DELAY,
    a_in: float = A_IN,
    f0: float = F0,
    sigma_add: float = SIGMA_ADD,
    dt: float = DT,
    t_total: float = T_TOTAL,
    t_burn: float = T_BURN,
):
    rng = np.random.default_rng(seed)
    n_steps = int(round(t_total / dt))
    burn_steps = int(round(t_burn / dt))
    t = np.arange(n_steps, dtype=float) * dt

    alpha = alpha_on if cond.asymmetry else 0.0
    g = g_on if cond.adaptation else 0.0
    tau_a = tau_a_on if cond.timescale_separation else tau_x

    w_ll = w0 * (1.0 + alpha)
    w_rr = w0 * (1.0 - alpha)
    delay_steps = max(1, int(round(tau_delay / dt)))

    x_l = np.zeros(n_steps, dtype=float)
    x_r = np.zeros(n_steps, dtype=float)
    a_l = np.zeros(n_steps, dtype=float)
    a_r = np.zeros(n_steps, dtype=float)

    x_l[:delay_steps + 1] = 0.05 + 0.01 * rng.standard_normal(delay_steps + 1)
    x_r[:delay_steps + 1] = 0.05 + 0.01 * rng.standard_normal(delay_steps + 1)
    a_l[:delay_steps + 1] = 0.02 + 0.01 * rng.standard_normal(delay_steps + 1)
    a_r[:delay_steps + 1] = 0.02 + 0.01 * rng.standard_normal(delay_steps + 1)

    f_l = f0 - delta_f / 2.0
    f_r = f0 + delta_f / 2.0

    for i in range(delay_steps, n_steps - 1):
        i_l = a_in * math.sin(2.0 * math.pi * f_l * t[i])
        i_r = a_in * math.sin(2.0 * math.pi * f_r * t[i])

        u_l = w_ll * x_l[i] - g * a_l[i] + c_on * x_r[i - delay_steps] + i_l
        u_r = w_rr * x_r[i] - g * a_r[i] + c_on * x_l[i - delay_steps] + i_r

        noise_l = sigma_add * math.sqrt(dt) * rng.standard_normal()
        noise_r = sigma_add * math.sqrt(dt) * rng.standard_normal()

        dx_l = (-x_l[i] + sigmoid(u_l)) / tau_x
        dx_r = (-x_r[i] + sigmoid(u_r)) / tau_x
        da_l = (-a_l[i] + x_l[i]) / tau_a
        da_r = (-a_r[i] + x_r[i]) / tau_a

        x_l[i + 1] = x_l[i] + dx_l * dt + noise_l
        x_r[i + 1] = x_r[i] + dx_r * dt + noise_r
        a_l[i + 1] = a_l[i] + da_l * dt
        a_r[i + 1] = a_r[i] + da_r * dt

    x_l_ss = x_l[burn_steps:]
    x_r_ss = x_r[burn_steps:]
    time_ss = t[burn_steps:]

    metrics = phase_metrics_from_signals(x_l_ss, x_r_ss, dt)
    metrics.update(
        {
            "condition": cond.name(),
            "condition_label": cond.label(),
            "delta_f": float(delta_f),
            "log10_delta_f": float(np.log10(delta_f)),
            "x_l_ss": x_l_ss,
            "x_r_ss": x_r_ss,
            "time_ss": time_ss,
        }
    )
    return metrics


# ============================================================
# Main analysis
# ============================================================
def run_main_analysis():
    conditions = [Condition(a, g, t) for a, g, t in itertools.product([0, 1], repeat=3)]

    trial_rows = []
    representative = None
    total_jobs = len(conditions) * len(DELTA_F_VALUES) * N_TRIALS
    done = 0

    for cond in conditions:
        for delta_f in DELTA_F_VALUES:
            for trial in range(N_TRIALS):
                seed = trial_seed("main", cond.name(), float(delta_f), trial)
                res = simulate_condition(cond, float(delta_f), seed)

                trial_rows.append(
                    {
                        "condition": cond.name(),
                        "condition_label": cond.label(),
                        "asymmetry": cond.asymmetry,
                        "adaptation": cond.adaptation,
                        "timescale_separation": cond.timescale_separation,
                        "delta_f": float(delta_f),
                        "log10_delta_f": float(np.log10(delta_f)),
                        "trial": int(trial),
                        "plv": res["plv"],
                        "mean_phase_lag": res["mean_phase_lag"],
                        "signed_mean_phase_lag": res["signed_mean_phase_lag"],
                        "circ_sd": res["circ_sd"],
                        "mean_domega_eff": res["mean_domega_eff"],
                        "D_phi": res["D_phi"],
                        "N_slip": res["N_slip"],
                        "r_slip": res["r_slip"],
                    }
                )

                if cond == Condition(1, 1, 1) and abs(delta_f - REPRESENTATIVE_DELTA_F) < 1e-12 and trial == 0:
                    representative = res

                done += 1
                if done % 100 == 0 or done == total_jobs:
                    print(f"Main analysis: {done}/{total_jobs}")

    trial_df = pd.DataFrame(trial_rows)
    trial_df.to_csv(os.path.join(OUTDIR, "condition_trial_metrics.csv"), index=False)

    summary_df = (
        trial_df.groupby(
            ["condition", "condition_label", "asymmetry", "adaptation", "timescale_separation", "delta_f", "log10_delta_f"],
            as_index=False,
        )
        .agg(
            plv_mean=("plv", "mean"),
            plv_sem=("plv", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            lag_mean=("mean_phase_lag", "mean"),
            lag_sem=("mean_phase_lag", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            signed_lag_mean=("signed_mean_phase_lag", "mean"),
            signed_lag_sem=("signed_mean_phase_lag", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            circ_sd_mean=("circ_sd", "mean"),
            circ_sd_sem=("circ_sd", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            mean_domega_eff_mean=("mean_domega_eff", "mean"),
            mean_domega_eff_sem=("mean_domega_eff", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            D_phi_mean=("D_phi", "mean"),
            D_phi_sem=("D_phi", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            N_slip_mean=("N_slip", "mean"),
            N_slip_sem=("N_slip", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
            r_slip_mean=("r_slip", "mean"),
            r_slip_sem=("r_slip", lambda x: np.std(x, ddof=1) / np.sqrt(len(x))),
        )
    )
    summary_df.to_csv(os.path.join(OUTDIR, "condition_mismatch_summary.csv"), index=False)

    sens_rows = []
    for cond_name, sub in trial_df.groupby("condition"):
        meta = sub.iloc[0]
        for trial, ts in sub.groupby("trial"):
            ts = ts.sort_values("delta_f")
            x = np.log10(ts["delta_f"].values)

            metrics = {
                "LAG": ts["mean_phase_lag"].values,
                "PLV": ts["plv"].values,
                "DOMEGA": ts["mean_domega_eff"].values,
                "DPHI": ts["D_phi"].values,
                "RSLIP": ts["r_slip"].values,
            }

            row = {
                "condition": cond_name,
                "condition_label": meta["condition_label"],
                "asymmetry": int(meta["asymmetry"]),
                "adaptation": int(meta["adaptation"]),
                "timescale_separation": int(meta["timescale_separation"]),
                "trial": int(trial),
            }

            for key, y in metrics.items():
                coef = np.polyfit(x, y, 1)
                pred = np.polyval(coef, x)
                row[f"S_{key}"] = float(coef[0])
                row[f"R2_{key}"] = float(r2_score(y, pred))

            sens_rows.append(row)

    sens_df = pd.DataFrame(sens_rows)
    sens_df.to_csv(os.path.join(OUTDIR, "trialwise_sensitivity_metrics.csv"), index=False)

    condition_rows = []
    for cond_name, sub in sens_df.groupby("condition"):
        meta = sub.iloc[0]

        ci_map = {}
        for key in ["LAG", "PLV", "DOMEGA", "DPHI", "RSLIP"]:
            ci_map[key] = bootstrap_ci(sub[f"S_{key}"].values, n_boot=BOOT_N, seed=trial_seed(f"{key}_ci", cond_name))

        baseline = summary_df[
            (summary_df["condition"] == cond_name) & (np.isclose(summary_df["delta_f"], REPRESENTATIVE_DELTA_F))
        ].iloc[0]

        row = {
            "condition": cond_name,
            "condition_label": meta["condition_label"],
            "asymmetry": int(meta["asymmetry"]),
            "adaptation": int(meta["adaptation"]),
            "timescale_separation": int(meta["timescale_separation"]),
            "PLV_at_0p1Hz": float(baseline["plv_mean"]),
            "LAG_at_0p1Hz": float(baseline["lag_mean"]),
            "DOMEGA_at_0p1Hz": float(baseline["mean_domega_eff_mean"]),
            "DPHI_at_0p1Hz": float(baseline["D_phi_mean"]),
            "RSLIP_at_0p1Hz": float(baseline["r_slip_mean"]),
        }

        for key in ["LAG", "PLV", "DOMEGA", "DPHI", "RSLIP"]:
            row[f"S_{key}_mean"] = float(sub[f"S_{key}"].mean())
            row[f"S_{key}_CI_low"] = float(ci_map[key][0])
            row[f"S_{key}_CI_high"] = float(ci_map[key][1])
            row[f"R2_{key}_mean"] = float(sub[f"R2_{key}"].mean())

        condition_rows.append(row)

    condition_df = pd.DataFrame(condition_rows).sort_values(["asymmetry", "adaptation", "timescale_separation"])
    condition_df.to_csv(os.path.join(OUTDIR, "condition_sensitivity_summary.csv"), index=False)
    condition_df.to_csv(os.path.join(OUTDIR, "results_table_main.csv"), index=False)

    factor_rows = []
    for metric in ["S_LAG", "S_PLV", "S_DOMEGA", "S_DPHI", "S_RSLIP"]:
        for factor in ["asymmetry", "adaptation", "timescale_separation"]:
            on_vals = sens_df.loc[sens_df[factor] == 1, metric].values
            off_vals = sens_df.loc[sens_df[factor] == 0, metric].values
            factor_rows.append(
                {
                    "metric": metric,
                    "factor": factor,
                    "mean_on": float(np.mean(on_vals)),
                    "mean_off": float(np.mean(off_vals)),
                    "effect_on_minus_off": float(np.mean(on_vals) - np.mean(off_vals)),
                }
            )
    factor_df = pd.DataFrame(factor_rows)
    factor_df.to_csv(os.path.join(OUTDIR, "factor_effects_summary.csv"), index=False)

    return trial_df, summary_df, sens_df, condition_df, factor_df, representative


# ============================================================
# Nonlinear analyses
# ============================================================
def run_nonlinear_analyses(summary_df, trial_df):
    local_rows = []
    turning_rows = []
    regime_rows = []
    model_compare_rows = []

    metrics_to_analyze = {
        "lag_mean": "lag_mean",
        "plv_mean": "plv_mean",
        "mean_domega_eff_mean": "mean_domega_eff_mean",
        "D_phi_mean": "D_phi_mean",
        "r_slip_mean": "r_slip_mean",
    }

    for cond_name, sub in summary_df.groupby("condition"):
        sub = sub.sort_values("log10_delta_f")
        x = sub["log10_delta_f"].values
        label = sub["condition_label"].iloc[0]

        for metric_label, col in metrics_to_analyze.items():
            y = sub[col].values

            mids, slopes = local_slopes(x, y)
            for xm, sl in zip(mids, slopes):
                local_rows.append(
                    {
                        "condition": cond_name,
                        "condition_label": label,
                        "metric": metric_label,
                        "mid_log10_delta_f": float(xm),
                        "local_slope": float(sl),
                    }
                )

            for tp in turning_points(x, y):
                turning_rows.append(
                    {
                        "condition": cond_name,
                        "condition_label": label,
                        "metric": metric_label,
                        "turn_type": tp["type"],
                        "log10_delta_f": tp["x"],
                        "value": tp["y"],
                        "index": tp["index"],
                    }
                )

            for regime_name, (lo, hi) in REGIME_BINS.items():
                if regime_name == "low":
                    mask = (x >= lo) & (x <= hi)
                else:
                    mask = (x > lo) & (x <= hi)
                if mask.sum() >= 3:
                    xr = x[mask]
                    yr = y[mask]
                    coef = np.polyfit(xr, yr, 1)
                    regime_rows.append(
                        {
                            "condition": cond_name,
                            "condition_label": label,
                            "regime": regime_name,
                            "metric": metric_label,
                            "slope": float(coef[0]),
                            "r2": float(r2_score(yr, np.polyval(coef, xr))),
                            "mean_value": float(np.mean(yr)),
                        }
                    )

            lin = np.polyfit(x, y, 1)
            quad = np.polyfit(x, y, 2)
            cubic = np.polyfit(x, y, 3)
            pw = piecewise_linear_two_segment(x, y)

            model_compare_rows.extend([
                {"condition": cond_name, "condition_label": label, "metric": metric_label, "model": "linear", "r2": float(r2_score(y, np.polyval(lin, x)))},
                {"condition": cond_name, "condition_label": label, "metric": metric_label, "model": "quadratic", "r2": float(r2_score(y, np.polyval(quad, x)))},
                {"condition": cond_name, "condition_label": label, "metric": metric_label, "model": "cubic", "r2": float(r2_score(y, np.polyval(cubic, x)))},
                {"condition": cond_name, "condition_label": label, "metric": metric_label, "model": "piecewise_linear", "r2": float(pw["r2"])},
            ])

    local_df = pd.DataFrame(local_rows)
    turning_df = pd.DataFrame(turning_rows)
    regime_df = pd.DataFrame(regime_rows)
    model_compare_df = pd.DataFrame(model_compare_rows)

    local_df.to_csv(os.path.join(OUTDIR, "nonlinear_local_slopes_summary.csv"), index=False)
    turning_df.to_csv(os.path.join(OUTDIR, "nonlinear_turning_points_summary.csv"), index=False)
    regime_df.to_csv(os.path.join(OUTDIR, "nonlinear_regime_summary.csv"), index=False)
    model_compare_df.to_csv(os.path.join(OUTDIR, "nonlinear_model_comparison_summary.csv"), index=False)

    return local_df, turning_df, regime_df, model_compare_df


# ============================================================
# Trialwise structure metrics
# ============================================================
def compute_trialwise_structure_metrics(trial_df):
    rows = []

    for cond_name, sub in trial_df.groupby("condition"):
        meta = sub.iloc[0]
        for trial, ts in sub.groupby("trial"):
            ts = ts.sort_values("delta_f")
            x = np.log10(ts["delta_f"].values)

            for metric_label, col in [("lag_mean", "mean_phase_lag"), ("plv_mean", "plv")]:
                y = ts[col].values
                mids, slopes = local_slopes(x, y)

                sign_change_count = 0
                for i in range(1, len(slopes)):
                    s1 = np.sign(slopes[i - 1])
                    s2 = np.sign(slopes[i])
                    if s1 != 0 and s2 != 0 and s1 != s2:
                        sign_change_count += 1

                high_mask = mids > 0.0
                positive_high = slopes[high_mask] > 0 if np.any(high_mask) else np.array([], dtype=bool)
                positive_high_len = longest_contiguous_true(positive_high)

                lin = np.polyfit(x, y, 1)
                cubic = np.polyfit(x, y, 3)
                pw = piecewise_linear_two_segment(x, y)

                r2_lin = r2_score(y, np.polyval(lin, x))
                r2_cubic = r2_score(y, np.polyval(cubic, x))
                r2_piece = float(pw["r2"])

                reg_slopes = {}
                for regime_name, (lo, hi) in REGIME_BINS.items():
                    if regime_name == "low":
                        mask = (x >= lo) & (x <= hi)
                    else:
                        mask = (x > lo) & (x <= hi)
                    if mask.sum() >= 3:
                        xr = x[mask]
                        yr = y[mask]
                        coef = np.polyfit(xr, yr, 1)
                        reg_slopes[regime_name] = float(coef[0])

                low_mid_diff = np.nan
                mid_high_diff = np.nan
                if "low" in reg_slopes and "mid" in reg_slopes:
                    low_mid_diff = reg_slopes["mid"] - reg_slopes["low"]
                if "mid" in reg_slopes and "high" in reg_slopes:
                    mid_high_diff = reg_slopes["high"] - reg_slopes["mid"]

                rows.append(
                    {
                        "condition": cond_name,
                        "condition_label": meta["condition_label"],
                        "asymmetry": int(meta["asymmetry"]),
                        "adaptation": int(meta["adaptation"]),
                        "timescale_separation": int(meta["timescale_separation"]),
                        "trial": int(trial),
                        "metric": metric_label,
                        "sign_change_count": int(sign_change_count),
                        "positive_high_len": int(positive_high_len),
                        "R2_linear": float(r2_lin),
                        "R2_cubic": float(r2_cubic),
                        "R2_piecewise": float(r2_piece),
                        "delta_R2_cubic_minus_linear": float(r2_cubic - r2_lin),
                        "delta_R2_piecewise_minus_linear": float(r2_piece - r2_lin),
                        "slope_diff_low_to_mid": float(low_mid_diff) if not np.isnan(low_mid_diff) else np.nan,
                        "slope_diff_mid_to_high": float(mid_high_diff) if not np.isnan(mid_high_diff) else np.nan,
                    }
                )

    structure_df = pd.DataFrame(rows)
    structure_df.to_csv(os.path.join(OUTDIR, "trialwise_structure_metrics.csv"), index=False)
    return structure_df


